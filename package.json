{
  "name": "@searchapi/n8n-nodes-searchapi",
  "version": "2.0.4",
  "description": "SearchApi.io nodes for n8n",
  "keywords": [
    "n8n-community-node-package"
  ],
  "license": "MIT",
  "homepage": "https://www.searchapi.io",
  "author": {
    "name": "SearchApi",
    "email": "support@searchapi.io"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SearchApi/n8n-nodes-searchapi.git"
  },
  "engines": {
    "node": ">=22"
  },
  "main": "index.js",
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/SearchApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/SearchApi/SearchApi.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "^0.17.0",
    "eslint": "9.32.0",
    "prettier": "3.6.2",
    "release-it": "^19.0.4",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
